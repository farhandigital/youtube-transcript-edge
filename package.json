{
  "name": "youtube-transcript-plus",
  "version": "1.2.0",
  "description": "Fetch transcript from a YouTube video",
  "type": "module",
  "main": "dist/youtube-transcript-plus.js",
  "module": "dist/youtube-transcript-plus.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "author": "ericmmartin",
  "keywords": [
    "youtube",
    "transcript"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/jest": "^30.0.0",
    "ajv": "^8.18.0",
    "globals": "^16.5.0",
    "https-proxy-agent": "^7.0.6",
    "i": "0.3.7",
    "jest": "^30.0.5",
    "lefthook": "^2.1.2",
    "lint-staged": "^16.1.5",
    "nock": "^14.0.10",
    "ts-jest": "^29.4.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InvictusNavarchus/youtube-transcript-edge.git"
